# ─── Server Environment Variables ────────────────────────────────────────────
# Copy this file to .env and fill in the values.

# Port the server listens on (default: 3001)
PORT=3001

# Node environment
NODE_ENV=development

# Client URL for CORS and call link generation
# In development: http://localhost:5173
# In production: your Vercel deployment URL, e.g. https://foreva.vercel.app
CLIENT_URL=http://localhost:5173

# Translation API key (optional — stub translation used if not set)
# TRANSLATION_API_KEY=

# Metered.ca TURN server (free tier: 500GB/month)
# Sign up at https://www.metered.ca/tools/openrelay/ to get these
# Without this, only STUN servers are used (may fail across different networks)
METERED_API_KEY=your_metered_api_key_here
METERED_APP_NAME=your_app_name
