# ─── Client Environment Variables ────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.

# API URL for the backend server (HTTP endpoints)
# In development: leave empty (Vite proxy handles it)
# In production: set to your Render server URL, e.g. https://foreva-server.onrender.com
VITE_API_URL=

# WebSocket URL for the signalling server
# In development: leave empty (defaults to ws://localhost:3001)
# In production: set to your Render server WSS URL, e.g. wss://foreva-server.onrender.com
VITE_WS_URL=
